# Plerona — environment template
# Copy to .env.local for local dev; set the same vars in Vercel for production.

# Public site URL — used for metadata, canonical, and Stripe redirect URLs.
NEXT_PUBLIC_SITE_URL=https://plerona.com

# ── Stripe (payments) ───────────────────────────────────────────────
# Server-side secret key (sk_test_… in test mode, sk_live_… in production).
# Until this is set, checkout runs in safe demo mode (no charge) and the
# flow proceeds straight to the confirmation page.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_…) from the Stripe webhook you create for
# the /api/webhook endpoint. Required for verified fulfillment.
STRIPE_WEBHOOK_SECRET=

# ── Email fulfillment (Resend) ──────────────────────────────────────
# API key from resend.com. Without it, emails are skipped (logged only).
RESEND_API_KEY=
# Verified sender. Defaults to Resend's sandbox sender until your domain
# is verified in Resend, e.g. FROM_EMAIL="Plerona <hello@plerona.com>".
FROM_EMAIL=
# Where the internal "new order" notification is sent.
NOTIFY_EMAIL=contact@plerona.com

# ── Order record (Supabase) ─────────────────────────────────────────
# Project URL + SERVICE ROLE key (server-only, never expose to the client).
# Run supabase/migrations/0001_orders.sql first. If unset, the record step
# is skipped and emails still send.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
